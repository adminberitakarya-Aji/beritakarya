{
  "info": {
    "_postman_id": "beritakarya-api-test",
    "name": "BeritaKarya API - Category & Site Management",
    "description": "Postman collection for testing multi-tenant category inheritance and site management endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Login (Superadmin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@beritakarya.co\",\n  \"password\": \"your_password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "🏢 Site Management (Superadmin Only)",
      "item": [
        {
          "name": "GET All Sites",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/sites?includeStats=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "sites"],
              "query": [
                {
                  "key": "includeStats",
                  "value": "true"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.beritakarya.co"
    },
    {
      "key": "access_token",
      "value": ""
    }
  ]
}