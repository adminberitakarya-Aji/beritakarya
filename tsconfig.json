{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@beritakarya/config": ["packages/config/src"],
      "@beritakarya/types": ["packages/types/src"],
      "@beritakarya/utils": ["packages/utils/src"]
    }

  },
  "exclude": ["node_modules", "dist", ".next", "coverage"]
}