DIRECT_URL="postgresql://beritakarya:GANTI_DENGAN_PASSWORD_KUAT@postgres:5432/beritakarya_prod"

# --- SECURITY & AUTHENTICATION ---
JWT_SECRET=ganti-dengan-string-acak-64-karakter
