# ── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://beritakarya:PASSWORD@localhost:5432/beritakarya_prod"
POSTGRES_USER="beritakarya"
POSTGRES_PASSWORD="ganti-dengan-password-kuat-min-20-karakter"
POSTGRES_DB="beritakarya_prod"

# ── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://:REDIS_PASSWORD@localhost:6379"
REDIS_PASSWORD="ganti-dengan-password-redis-kuat"

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET="ganti-dengan-random-string-minimal-64-karakter-acak"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── AI ─────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
AI_MODEL="gpt-4o"
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=3

# ── App URLs ───────────────────────────────────────────────
WEB_URL="https://bandung.beritakarya.com"
API_URL="https://api.beritakarya.com"
NEXT_PUBLIC_API_URL="https://api.beritakarya.com"
IMAGE_WEB="ghcr.io/your-org/beritakarya/web:latest"
IMAGE_API="ghcr.io/your-org/beritakarya/api:latest"

# ── Node ───────────────────────────────────────────────────
NODE_ENV="production"
PORT=4000
