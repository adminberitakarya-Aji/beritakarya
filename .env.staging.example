# ── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://beritakarya:replace-with-strong-password@postgres:5432/beritakarya_staging"
POSTGRES_USER="beritakarya"
POSTGRES_PASSWORD="replace-with-strong-staging-password-min-20-chars"
POSTGRES_DB="beritakarya_staging"

# ── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://:replace-with-strong-redis-password@redis:6379"
REDIS_PASSWORD="replace-with-strong-redis-password-min-20-chars"

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET="replace-with-random-secret-min-64-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── AI ─────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
AI_MODEL="gpt-4o-mini"

# ── App URLs ───────────────────────────────────────────────
WEB_URL="http://bandung.staging.beritakarya.com"
API_URL="http://staging.beritakarya.com:4000"
NEXT_PUBLIC_API_URL="http://staging.beritakarya.com:4000"
IMAGE_WEB="ghcr.io/your-org/beritakarya/web:latest"
IMAGE_API="ghcr.io/your-org/beritakarya/api:latest"

# ── Node ───────────────────────────────────────────────────
NODE_ENV="staging"
PORT=4000
