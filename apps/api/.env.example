# PORT — API port (default 3001 for development)
PORT=3001

# DATABASE — PostgreSQL connection strings (Supabase/Local)
# DATABASE_URL is for the application (pooling supported)
# DIRECT_URL is for migrations (direct connection)
DATABASE_URL="postgresql://user:password@localhost:5432/beritakarya"
DIRECT_URL="postgresql://user:password@localhost:5432/beritakarya"

# JWT — REQUIRED: Random string (min 64 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="ganti-dengan-string-acak-panjang"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# AI (Optional)
OPENAI_API_KEY=""
AI_MODEL="gpt-4o"
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=3

# APPS CONFIG
WEB_URL="http://localhost:3000"
API_URL="http://localhost:3001"
NODE_ENV="development"
