generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Site {
  id        String   @id
  name      String
  domain    String   @unique
  description String?
  logoUrl     String?
  footerText  String?
  address     String?
  contactEmail String?
  phone       String?
  aboutUs     String? @db.Text
  codeOfEthics String? @db.Text
  editorial   String? @db.Text
  advertising String? @db.Text
  socialLinks Json?    @default("{}")
  appearance  Json?    @default("{\"primaryColor\":\"#e11d48\"}")
  trendingTopics Json?    @default("[]")
  deletedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users          User[]
  articles       Article[]
  categories     Category[]
  advertisements Advertisement[]
  newsletterSubscribers NewsletterSubscriber[]
  comments              Comment[]
  pageViews             PageView[]
  kycViewLogs           KYCViewLog[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("reader")
  siteId       String?
  deletedAt    DateTime?

  // KYC Fields
  bio              String?   @db.Text
  idCardPath       String?
  familyCardPath   String?
  isVerified       Boolean   @default(false)
  kycSubmittedAt   DateTime?
  kycNotes         String?
  kycReviewedBy    String?   // userId admin yang approval
  kycReviewedAt    DateTime?
  kycConsentGivenAt DateTime? // Waktu user setuju kebijakan data
  kycDataExpiresAt DateTime?  // Auto-delete after X years (GDPR compliance)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site          Site?          @relation(fields: [siteId], references: [id])
  articles      Article[]
  refreshTokens RefreshToken[]
  comments      Comment[]
  kycViewLogs   KYCViewLog[]

  @@index([siteId])
  @@index([email])
  @@index([isVerified])
  @@index([kycSubmittedAt])
  @@index([deletedAt])
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String
  siteId      String?  // NULL = global category (available to all sites)
  isGlobal    Boolean  @default(false) @map("is_global")
  description String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site        Site?     @relation(fields: [siteId], references: [id])
  articles    Article[]

  // Unique constraint: allows (slug, NULL) for global categories
  // and (slug, siteId) for site-specific categories
  @@unique([slug, siteId])
  @@index([siteId])
  @@index([isGlobal])
  @@index([deletedAt])
}

model Advertisement {
  id        String   @id @default(uuid())
  siteId    String
  slot      String   // 'leaderboard', 'in_feed', 'sidebar'
  code      String?  // HTML/JS snippet like Google AdSense
  imageUrl  String?  // If they just want to upload an image banner
  linkUrl   String?  // Where the banner clicks to
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  site      Site     @relation(fields: [siteId], references: [id])

  @@unique([siteId, slot])
}

model Article {
  id              String   @id @default(uuid())
  title           String
  slug            String
  siteId          String
  categoryId      String?
  authorId        String
  blocks          Json     @default("[]")
  tags            Json     @default("[]")

  // Editorial Workflow
  // draft | submitted | review | revision | approved | scheduled | published | archived
  status          String   @default("draft")
  reviewedBy      String?  // userId pimred yang mereview
  reviewedAt      DateTime?
  reviewNotes     String?  // Catatan revisi dari editor
  scheduledAt     DateTime? // Waktu terbit yang dijadwalkan

  // SEO
  metaTitle       String?
  metaDescription String?
  featuredImage   String?  // URL gambar utama

  // Article Metadata
  wordCount       Int?     // Jumlah kata
  readingTimeMin  Int?     // Estimasi menit baca
  viewCount       Int      @default(0)
  shareCount      Int      @default(0)
  versions        ArticleVersion[]

  // Editorial Flags
  isBreaking      Boolean  @default(false)
  isExclusive     Boolean  @default(false)
  isFeatured      Boolean  @default(false)

  publishedAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  site     Site      @relation(fields: [siteId], references: [id])
  author   User      @relation(fields: [authorId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  comments Comment[]
  pageViews PageView[]

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([authorId])
  @@index([categoryId])
  @@index([scheduledAt])
  @@index([publishedAt, viewCount])
  @@index([siteId, status, publishedAt])
  @@index([deletedAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
}

model AIUsage {
  id           String   @id @default(uuid())
  userId       String
  siteId       String
  action       String
  inputLength  Int
  outputLength Int
  latencyMs    Int
  success      Boolean
  createdAt    DateTime @default(now())

  @@index([userId, action])
  @@index([siteId])
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String
  siteId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@unique([siteId, email])
  @@index([siteId])
}

model Media {
  id             String   @id @default(uuid())
  url            String
  thumbUrl       String
  width          Int
  height         Int
  originalFormat String
  size           Int
  altText        String?  // Teks alt untuk aksesibilitas & SEO
  caption        String?  // Keterangan foto
  credit         String?  // Kredit/sumber foto
  userId         String
  siteId         String?
  createdAt      DateTime @default(now())

  @@index([siteId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  articleId String
  siteId    String
  authorId  String?  // Optional: if logged in
  authorName String? // If guest
  authorEmail String?
  status    String   @default("pending") // pending | approved | spam
  parentId  String?  // For nested replies
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  site      Site     @relation(fields: [siteId], references: [id])
  user      User?    @relation(fields: [authorId], references: [id])
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  @@index([articleId])
  @@index([siteId, status])
}

model PageView {
  id        String   @id @default(uuid())
  siteId    String
  articleId String?
  path      String   // e.g. /artikel/slug atau /
  referrer  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  site      Site     @relation(fields: [siteId], references: [id])
  article   Article? @relation(fields: [articleId], references: [id])

  @@index([siteId, createdAt])
  @@index([articleId, createdAt])
}

model ArticleVersion {
  id        String   @id @default(uuid())
  articleId String
  title     String
  blocks    Json     @default("[]")
  version   Int
  authorId  String
  createdAt DateTime @default(now())

  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

// Audit log untuk akuntabilitas semua aksi redaksi
model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  siteId     String
  action     String   // e.g. article.publish | article.review | user.create | settings.update
  entityType String?  // 'article' | 'user' | 'site' | 'category'
  entityId   String?  // ID entitas yang diubah
  oldValue   Json?    // State sebelumnya
  newValue   Json?    // State sesudahnya
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([siteId, action])
  @@index([entityId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  siteId    String
  type      String   // e.g. article_submitted | article_reviewed | mention
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([siteId])
}

// Audit trail untuk akses file KYC
model KYCViewLog {
  id        String   @id @default(uuid())
  userId    String   // user yang KYC-nya dilihat
  viewerId  String   // admin yang melihat
  siteId    String
  fileType  String   // 'ktp' | 'kk' | 'bio'
  viewedAt  DateTime @default(now())
  ipAddress String?
  userAgent String?

  user      User     @relation(fields: [userId], references: [id])
  site      Site     @relation(fields: [siteId], references: [id])

  @@index([userId, viewedAt])
  @@index([viewerId])
  @@index([siteId])
}
