generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  id        String   @id
  name      String
  domain    String   @unique
  trendingTopics Json?    @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users          User[]
  articles       Article[]
  categories     Category[]
  advertisements Advertisement[]
  newsletterSubscribers NewsletterSubscriber[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("reader")
  siteId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site          Site?          @relation(fields: [siteId], references: [id])
  articles      Article[]
  refreshTokens RefreshToken[]

  @@index([siteId])
  @@index([email])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String
  siteId    String
  createdAt DateTime  @default(now())

  site      Site      @relation(fields: [siteId], references: [id])
  articles  Article[]

  @@unique([siteId, slug])
}

model Advertisement {
  id        String   @id @default(uuid())
  siteId    String
  slot      String   // 'leaderboard', 'in_feed', 'sidebar'
  code      String?  // HTML/JS snippet like Google AdSense
  imageUrl  String?  // If they just want to upload an image banner
  linkUrl   String?  // Where the banner clicks to
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  site      Site     @relation(fields: [siteId], references: [id])

  @@unique([siteId, slot])
}

model Article {
  id              String   @id @default(uuid())
  title           String
  slug            String
  siteId          String
  categoryId      String?
  authorId        String
  blocks          Json     @default("[]")
  tags            Json     @default("[]")
  status          String   @default("draft")
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  site     Site      @relation(fields: [siteId], references: [id])
  author   User      @relation(fields: [authorId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([authorId])
  @@index([categoryId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIUsage {
  id           String   @id @default(uuid())
  userId       String
  siteId       String
  action       String
  inputLength  Int
  outputLength Int
  latencyMs    Int
  success      Boolean
  createdAt    DateTime @default(now())

  @@index([userId, action])
  @@index([siteId])
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String
  siteId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@unique([siteId, email])
  @@index([siteId])
}

model Media {
  id             String   @id @default(uuid())
  url            String
  thumbUrl       String
  width          Int
  height         Int
  originalFormat String
  size           Int
  userId         String
  siteId         String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([siteId])
}