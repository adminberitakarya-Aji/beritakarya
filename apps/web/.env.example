# APPS — NEXT_PUBLIC_ prefix is required for browser-side access
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_URL="http://localhost:3000"

# DATABASE (Server-side only)
DATABASE_URL="postgresql://user:password@localhost:5432/beritakarya"

# JWT (For middleware validation)
JWT_SECRET="ganti-dengan-string-acak-panjang"

# AI (Optional)
OPENAI_API_KEY=""

# ANALYTICS (Optional)
NEXT_PUBLIC_GA_ID=""

# ENVIRONMENT
NODE_ENV="development"
